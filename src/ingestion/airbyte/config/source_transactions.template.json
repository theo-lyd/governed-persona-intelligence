{
  "name": "gpi-transactions-csv",
  "sourceDefinitionId": "${AIRBYTE_SOURCE_DEF_AZURE_BLOB_ID}",
  "workspaceId": "${AIRBYTE_WORKSPACE_ID}",
  "connectionConfiguration": {
    "container": "${TRANSACTION_CONTAINER}",
    "path_prefix": "${TRANSACTION_PREFIX}",
    "format": {
      "filetype": "csv",
      "delimiter": ",",
      "quote_char": "\"",
      "has_header": true
    },
    "provider": {
      "account_name": "${AZURE_STORAGE_ACCOUNT_NAME}",
      "account_key": "${AZURE_STORAGE_ACCOUNT_KEY}"
    }
  }
}
